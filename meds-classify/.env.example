# Copy to .env and adjust if needed. On PowerShell, set these in the session before
# running, e.g.:   $env:OLLAMA_MODEL="aya:8b"; node classify-meds.js

# Where the local Ollama server listens (default is fine after a normal install)
OLLAMA_URL=http://localhost:11434

# Which local model to use. Pull it first:  ollama pull qwen2.5:7b
# Good Arabic-capable options: qwen2.5:7b  ·  aya:8b  ·  gemma2:9b
OLLAMA_MODEL=qwen2.5:7b

# Per-call timeout in ms (raise on slower machines / bigger models)
OLLAMA_TIMEOUT_MS=120000

# Firebase service account. If omitted, the script also looks for
# ./serviceAccount.json and ../fb-classify/serviceAccount.json
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
